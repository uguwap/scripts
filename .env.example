# ============================================================================
# ПОДКЛЮЧЕНИЕ К БАЗАМ ДАННЫХ
# ============================================================================

# --- ClickHouse PROD (через SSH туннель) ---
# Используется в: egrul_report.py
SSH_HOST=your-ssh-host.example.com
SSH_PORT=22
SSH_USER=your_ssh_user
SSH_PASSWORD=your_ssh_password_here

CH_REMOTE_HOST=0.0.0.0
CH_REMOTE_PORT=9000
CH_USER=your_ch_user
CH_PASSWORD=your_ch_prod_password_here
CH_DATABASE=analytic

# --- ClickHouse DEV (прямое подключение) ---
# Используется в: llm_tag_experiment/run_classification.py
CH_DEV_HOST=your-ch-dev-host.example.com
CH_DEV_PORT=8123
CH_DEV_USER=your_ch_user
CH_DEV_PASSWORD=your_ch_dev_password_here
CH_DEV_DATABASE=analytic

# ============================================================================
# LLM API КЛЮЧИ
# ============================================================================

# Используется в: llm_tag_experiment (classify_payment_purposes_llm.py, run_classify.ps1)
LLM_API_KEY=your_llm_api_key_here
LLM_BASE_URL=https://your-llm-api.example.com/v1
LLM_MODEL=deepseek-ai/DeepSeek-R1-Distill-Qwen-32B
LLM_PROVIDER=claude
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.0
LLM_ENABLED=1
LLM_BATCH_SIZE=10

# ============================================================================
# Postgres (для llm_tag_experiment: load_results_to_postgres, pgvector_experiment)
# ============================================================================
PGHOST=localhost
PGPORT=5432
PGDATABASE=ai_referent
PGUSER=your_pg_user
PGPASSWORD=your_pg_password_here

# ============================================================================
# ПАРАМЕТРЫ СКРИПТОВ
# ============================================================================

# egrul_report.py
DAYS_BACK=30

# llm_tag_experiment/run_classification.py
BATCH_SIZE=40
LLM_TIMEOUT=180
LLM_MAX_RETRIES=3
SAMPLE_SIZE=200

# ----------------------------------------------------------------------------
# Локально: скопируй этот файл в .env и подставь свои значения.
# Файл .env в репозиторий не коммитится (см. .gitignore).
# ----------------------------------------------------------------------------
